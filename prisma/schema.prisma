// Schéma Relmo — cf. docs/PROJET.md §7 (Modèle de données).
// SQLite en V1 (mono-utilisateur, local). Migration Postgres possible plus tard.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Un client (la personne/entreprise pour qui on gère des sites).
model Client {
  id        String   @id @default(cuid())
  nom       String
  email     String?
  telephone String?
  statut    String   @default("actif") // prospect | actif | ancien
  source       String? // canal d'acquisition (cf. SOURCES) — F14/marketing
  sourceDetail String? // qui a recommandé / quelle campagne
  secteur      String? // secteur d'activité (niche)
  notes     String?
  portailActif Boolean @default(false) // portail client (F15) activé ?
  portailToken String? @unique // lien magique (non devinable)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sites        Site[]
  devis        Devis[]
  interactions Interaction[]
  photos       Photo[]
  factures     Facture[]
}

// Un site géré pour un client (1 client -> 0..n sites).
model Site {
  id              String    @id @default(cuid())
  clientId        String
  nom             String
  url             String?
  repoGitUrl      String?
  hebergeur       String?
  stack           String? // ex. "Next.js"
  contact         String? // interlocuteur (ex. qui fournit le contenu)
  statut          String    @default("actif") // actif | en_pause | archive
  dateMiseEnLigne DateTime?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  client    Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  contrats  Contrat[]
  devis     Devis[]
  factures  Facture[]

  @@index([clientId])
}

// Le « vendu » récurrent attaché à un site.
model Contrat {
  id             String    @id @default(cuid())
  siteId         String
  libelle        String
  montantMensuel Float     @default(0) // en euros
  montantCreation Float    @default(0) // one-shot (hors MRR)
  formule        String?   // essentiel | pro | suivi | sur_mesure (repris du devis) — cf. FORMULES
  dateDebut      DateTime  @default(now())
  dateFin        DateTime?
  statut         String    @default("actif") // actif | en_pause | resilie
  facturationDemarree Boolean @default(true) // false = actif & démarré mais pas encore facturé → exclu du MRR facturé (compté en « en attente de facturation »)
  note           String?
  motifResiliation String? // si résilié : pourquoi (signal de churn — F14)
  devisId        String?   @unique // devis à l'origine du contrat
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  site        Site         @relation(fields: [siteId], references: [id], onDelete: Cascade)
  devis       Devis?       @relation(fields: [devisId], references: [id])
  engagements Engagement[]

  @@index([siteId])
}

// Une ligne d'engagement récurrent d'un contrat (ce qui est vendu, par mois).
model Engagement {
  id             String  @id @default(cuid())
  contratId      String
  type           String // ex. "article_seo", "maj_securite"
  libelle        String
  quantiteParMois Int    @default(1)
  recurrence     String  @default("mensuelle") // mensuelle | ...
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  contrat   Contrat    @relation(fields: [contratId], references: [id], onDelete: Cascade)
  livrables Livrable[]

  @@index([contratId])
}

// Le « livré » : instancié par mois à partir des engagements actifs.
model Livrable {
  id           String    @id @default(cuid())
  engagementId String
  periode      String // "AAAA-MM"
  semaine      String? // lundi de la semaine "AAAA-MM-JJ" si cadence hebdo (sinon null = mensuel)
  libelle      String
  statut       String    @default("a_faire") // a_faire | fait | non_applicable
  faitLe       DateTime?
  source       String    @default("manuel") // manuel | git
  visibleClient Boolean  @default(true) // masquable dans le portail client (F15)
  note         String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  engagement Engagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)

  @@index([engagementId])
  @@index([periode])
  @@index([semaine])
}

// --- V1.5 : pilotage commercial & objectif ---

// Une proposition commerciale (F10). Un devis accepté se convertit en Contrat.
model Devis {
  id                    String    @id @default(cuid())
  clientId              String
  siteId                String? // site visé (optionnel tant que pas signé)
  libelle               String
  montantCreation       Float     @default(0)
  montantMensuelPropose Float     @default(0)
  formule               String?   // essentiel | pro | suivi | sur_mesure — cf. FORMULES (paliers de prix)
  statut                String    @default("brouillon") // brouillon | envoye | en_nego | accepte | refuse | expire
  dateEnvoi             DateTime?
  dateRelance           DateTime?
  dateDecision          DateTime?
  note                  String?
  motifPerte            String? // si refusé/expiré : pourquoi (prix, timing…)
  pdfUrl                String? // PDF du devis rattaché (importé/analysé)
  dateVueClient         DateTime? // 1re consultation côté portail (F15)
  accepteLe             DateTime? // acceptation en ligne par le client (F15)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  client       Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  site         Site?         @relation(fields: [siteId], references: [id], onDelete: SetNull)
  contrat      Contrat? // contrat issu de ce devis (si accepté)
  interactions Interaction[]

  @@index([clientId])
  @@index([statut])
}

// Un échange de négo journalisé (F10). Saisie rapide.
model Interaction {
  id            String   @id @default(cuid())
  clientId      String
  devisId       String?
  canal         String // whatsapp | email | tel | autre
  direction     String   @default("sortant") // entrant | sortant
  date          DateTime @default(now())
  resume        String
  contenu       String?
  pieceJointeUrl String?
  createdAt     DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  devis  Devis? @relation(fields: [devisId], references: [id], onDelete: SetNull)

  @@index([clientId])
}

// Le cap de MRR à atteindre (F11). Un seul actif à la fois en pratique.
model ObjectifMRR {
  id           String   @id @default(cuid())
  montantCible Float     @default(3000)
  mrrDepart    Float     @default(0)
  dateDebut    DateTime  @default(now())
  dateCible    DateTime
  actif        Boolean   @default(true)
  note         String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// Photo mensuelle du MRR (historique → courbe d'évolution + deltas).
model MrrSnapshot {
  id         String   @id @default(cuid())
  periode    String   @unique // AAAA-MM
  mrr        Float    @default(0)
  potentiel  Float    @default(0)
  nbClients  Int      @default(0)
  nbContrats Int      @default(0)
  capturedAt DateTime @default(now())
}

// --- Phase 2 : portail client (F15) — factures ---

// Une facture rattachée à un client (PDF optionnel sur Vercel Blob). Visible
// dans le portail. Saisie manuelle en V1 (Indy n'expose pas d'API — cf. F13).
model Facture {
  id           String    @id @default(cuid())
  clientId     String
  siteId       String?
  numero       String
  periode      String // "AAAA-MM"
  montant      Float     @default(0)
  statut       String    @default("emise") // emise | payee | en_retard
  dateEmission DateTime  @default(now())
  dateEcheance DateTime?
  pdfUrl       String? // PDF rattaché (Vercel Blob)
  pathnamePdf  String? // chemin blob (pour suppression)
  source       String    @default("manuel") // manuel | indy
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  site   Site?  @relation(fields: [siteId], references: [id], onDelete: SetNull)

  @@index([clientId])
}

// --- Phase 2 : portail client (F15) — dépôt photos par le client ---

// Une photo déposée par le client dans son espace (stockage Vercel Blob ;
// la base ne garde que les métadonnées). Triée en dossier par date (EXIF).
model Photo {
  id        String    @id @default(cuid())
  clientId  String
  dossier   String // "AAAA-MM" — tri par date de prise (EXIF) sinon upload
  nom       String
  url       String // URL publique Vercel Blob
  pathname  String // chemin blob (pour suppression)
  taille    Int // octets (pour le quota global 5 Go)
  largeur   Int?
  hauteur   Int?
  prisLe    DateTime? // date EXIF si disponible
  createdAt DateTime  @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([dossier])
}

// --- Bonus : wish-list / gamification (paliers de MRR) ---

// Une envie d'achat. Se « débloque » quand le MRR rend l'objet abordable
// (prix <= Reglage.pourcentagePlafond % du MRR mensuel). Cf. src/lib/wishlist.ts.
model Envie {
  id        String    @id @default(cuid())
  libelle   String
  prix      Float     @default(0)
  url       String? // lien produit (optionnel)
  categorie String? // bureau | materiel | formation | plaisir | autre
  note      String?
  priorite  Int       @default(0) // ordre d'affichage manuel (desc)
  achete    Boolean   @default(false)
  acheteLe  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// Réglages globaux de l'app (singleton, id fixe "singleton").
model Reglage {
  id                 String   @id @default("singleton")
  pourcentagePlafond Float    @default(30) // wish-list : seuil d'abordabilité (% du MRR)
  // Paliers de prix courants (grille publique — cf. brief §4). L'Essentiel monte
  // par paliers (700 → 850 → 1000) à mesure que les références s'accumulent.
  palierEssentiel    Float    @default(700)
  palierPro          Float    @default(1200)
  tarifSuivi         Float    @default(90)
  // Campagne de prospection (envoi SMTP). Contenus injectés dans chaque mail.
  signatureEmail     String? // pied de signature (nom, site, tél…)
  optOutTexte        String? // mention opt-out RGPD (défaut : DEFAUT_OPT_OUT)
  lienRealisation    String? // URL de réalisation qui remplace [lien d'une réalisation]
  // Prospection partenaires : modèle de rémunération proposé dans les pitchs.
  // Forcé à « reciprocite » pour les experts-comptables (déontologie), quel que soit ce réglage.
  modeleRemu         String  @default("reciprocite") // commission | reciprocite | les_deux
  // Relances automatiques (cron). OFF par défaut : rien ne part tant qu'on ne l'active pas ici.
  relanceAutoActive  Boolean  @default(false)
  // Prospection automatique (cron 2×/jour : découverte + audit → file d'envoi). OFF par défaut.
  prospectionAutoActive Boolean @default(false)
  prospectionRotation   Int     @default(0) // compteur de rotation villes/secteurs entre runs
  updatedAt          DateTime @updatedAt
}

// --- Prospection sortante : moteur de découverte (scraping Places + audit IA) ---

// Un prospect "froid" découvert par scraping Google Places ou import CSV, avant
// qu'il devienne un Client. Audité (site + contact + score + accroches) à la
// demande. Quand on décide d'attaquer, on le convertit en Client (statut prospect).
// Dédup : `domaine` (site) et `placeId` (Google) sont uniques — Postgres tolère
// plusieurs NULL, donc les prospects sans site coexistent.
model Prospect {
  id        String  @id @default(cuid())
  nom       String
  site      String? // URL du site (vide = prospect chaud, site à créer)
  domaine   String? @unique // hôte normalisé, clé de dédup
  ville     String?
  activite  String? // mot-clé secteur ayant remonté ce prospect
  telephone String?
  email     String? // meilleur email trouvé à l'audit
  region    String?
  secteur   String? // clé de secteur (habitat | sante | ...)
  campagne  String? // groupe/phase de prospection (ex. « Phase 1 ») pour trier
  placeId   String? @unique // identifiant Google Places (dédup)

  // Mode V2 « partenaires » (apporteurs d'affaires). cible=client → flux V1 inchangé.
  cible          String  @default("client") // client | partenaire
  metier         String? // comptable | graphiste | agence_web | adjacent (si cible=partenaire)
  flagConcurrent Boolean @default(false) // offre web détectée → jamais de pitch automatique
  flagAQualifier Boolean @default(false) // agence web → qualification manuelle obligatoire
  atouts         String? // raisons du score partenaire, jointes par " • "
  nbAvis         Int? // nombre d'avis Google (proxy volume de portefeuille)
  noteGoogle     Float? // note moyenne Google

  // Audit du site (rempli à la demande)
  statutAudit      String  @default("a_auditer") // a_auditer | ok | aucun_site | erreur
  score            Int? // 0-100 (potentiel commercial estimé)
  design           String?
  anciennete       String?
  pointsFaibles    String? // joints par " • "
  emailsTous       String? // tous les emails captés, séparés par espace
  siret            String?
  dirigeant        String?
  linkedin         String?
  accrocheEmail    String?
  accrocheLinkedin String?

  // Suivi commercial / pipeline de prospection
  statut         String    @default("nouveau") // nouveau | a_contacter | contacte | ecarte | converti
  canalContact   String? // email | linkedin | instagram — par quel canal le 1er contact a été fait
  messageEnvoye  String? // le message réellement envoyé (édité par l'user) → apprend son style
  contacteLe     DateTime? // 1er message envoyé (mail/LinkedIn/DM)
  relanceLe      DateTime? // prochaine relance prévue (contacteLe + 5 j, puis reconduite)
  relanceFaiteLe DateTime? // dernière relance effectuée
  reponduLe      DateTime? // 1re réponse reçue (détectée par IMAP ou saisie manuelle) — dénominateur du taux de réponse
  optOutLe       DateTime? // a répondu STOP / demandé à ne plus être contacté — plus jamais de relance
  dernierMessageId String? // Message-ID du dernier mail envoyé (match des réponses + threading des relances)
  dernierObjet     String? // objet du dernier mail envoyé (relance répondue dans le même fil : « Re: … »)
  nbRelances     Int       @default(0)
  clientId       String? // Client créé à la conversion (lien souple, pas de FK)
  note           String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([secteur])
  @@index([statut])
  @@index([score])
  @@index([cible])
}

// To-do quotidienne générée (F12).
model Tache {
  id         String   @id @default(cuid())
  date       String // AAAA-MM-JJ (jour de création / d'échéance)
  semaine    String? // lundi de la semaine "AAAA-MM-JJ" — clé du Kanban hebdo
  libelle    String
  note       String? // détail libre (édition façon Notion)
  type       String   @default("autre") // livrable | relance_devis | prospection | technique | autre
  refType    String? // livrable | devis | client
  refId      String?
  priorite   String   @default("normale") // basse | normale | haute
  statut     String   @default("a_faire") // a_faire | en_cours | fait | reporte
  genereAuto Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([date])
  @@index([semaine])
}
